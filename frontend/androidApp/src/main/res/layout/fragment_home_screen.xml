<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F1EA"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:id="@+id/groupsRoot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Trip Groups"
                    android:textColor="#1C1A17"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Create a group, add trip expenses, and settle up cleanly."
                    android:textColor="#6C6258"
                    android:textSize="14sp" />

                <LinearLayout
                    android:id="@+id/groupsListPage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="All Groups"
                            android:textColor="#1C1A17"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/openCreateGroupDialogButton"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text="+"
                            android:textAllCaps="false"
                            android:textColor="#1C1A17"
                            android:textSize="24sp"
                            app:backgroundTint="#D8C5A5"
                            app:cornerRadius="18dp"
                            app:strokeWidth="0dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/groupsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/groupExpensesPage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <Button
                        android:id="@+id/backToGroupsButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="#D8C5A5"
                        android:text="Back to Groups"
                        android:textColor="#1C1A17" />

                    <TextView
                        android:id="@+id/selectedGroupTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Group"
                        android:textColor="#1C1A17"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Expenses"
                            android:textColor="#1C1A17"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/openCreateExpenseDialogButton"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text="+"
                            android:textAllCaps="false"
                            android:textColor="#1C1A17"
                            android:textSize="24sp"
                            app:backgroundTint="#D8C5A5"
                            app:cornerRadius="18dp"
                            app:strokeWidth="0dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/expensesContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/expenseDetailsPage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <Button
                        android:id="@+id/backToExpensesButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="#D8C5A5"
                        android:text="Back to Expenses"
                        android:textColor="#1C1A17" />

                    <TextView
                        android:id="@+id/expenseInfoText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Expense"
                        android:textColor="#1C1A17"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/addParticipantInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="#FFFDF8"
                        android:hint="Participant username"
                        android:inputType="text"
                        android:padding="14dp" />

                    <Button
                        android:id="@+id/addParticipantButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:backgroundTint="#1C1A17"
                        android:text="Add Participant"
                        android:textColor="#F8F3EA" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Participants"
                        android:textColor="#1C1A17"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/participantsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <TextView
                        android:id="@+id/expenseSettlementsText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Settlement"
                        android:textColor="#3A342E" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/usersRoot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="People"
                    android:textColor="#1C1A17"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Manage the usernames available in the app."
                    android:textColor="#6C6258"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="All Users"
                        android:textColor="#1C1A17"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/openCreateUserDialogButton"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="+"
                        android:textAllCaps="false"
                        android:textColor="#1C1A17"
                        android:textSize="24sp"
                        app:backgroundTint="#D8C5A5"
                        app:cornerRadius="18dp"
                        app:strokeWidth="0dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/usersContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomTabBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1C1A17"
        android:elevation="10dp"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingTop="10dp"
        android:paddingEnd="14dp"
        android:paddingBottom="18dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/groupsTabButton"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="Groups"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:textStyle="bold"
            app:cornerRadius="18dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/usersTabButton"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="Users"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:textStyle="bold"
            app:cornerRadius="18dp" />
    </LinearLayout>
</LinearLayout>
